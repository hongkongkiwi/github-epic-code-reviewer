{
  "$schema": "./epic-code-reviewer.schema.json",
  "post_mode": "both",
  "min_confidence": 0.72,
  "max_inline_comments": 8,
  "max_files": 60,
  "max_diff_chars": 120000,
  "context_lines": 80,
  "max_context_chars": 60000,
  "fail_on_block": false,
  "dry_run": false,
  "dry_run_path": "epic-code-reviewer-output.json",
  "judge_enabled": true,
  "dedupe_comments": true,
  "check_run_enabled": true,
  "include_symbol_context": true,
  "include_related_files": true,
  "memory_path": ".github/epic-code-reviewer-memory.json",
  "task_memory_path": ".github/epic-code-reviewer-task-memory.md",
  "audit_log_path": ".github/epic-code-reviewer-command-audit.jsonl",
  "patch_artifact_path": "epic-code-reviewer-suggested.patch",
  "auto_review_enabled": true,
  "skip_judge_on_low_risk": true,
  "risk_tier_passes": {
    "low": [
      "bug-regression"
    ],
    "medium": [
      "bug-regression",
      "tests",
      "api-compatibility"
    ],
    "high": [
      "bug-regression",
      "security",
      "tests",
      "api-compatibility",
      "deploy-config",
      "llm-agent",
      "tool-permissions",
      "stale-claims"
    ]
  },
  "review_rule_files": [
    "REVIEW.md"
  ],
  "path_rule_dirs": [
    ".github/epic-code-reviewer-rules"
  ],
  "specialist_passes": [
    "bug-regression",
    "security",
    "tests",
    "api-compatibility",
    "deploy-config",
    "llm-agent",
    "tool-permissions",
    "stale-claims"
  ],
  "ci_log_paths": [
    "test-results/reviewer-ci.log",
    "semgrep-results.json",
    "codeql-results.txt"
  ],
  "scanner_log_paths": [
    "semgrep-results.json",
    "codeql-results.sarif",
    "codeql-results.txt"
  ],
  "ignore_paths": [
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "dist/**",
    "build/**",
    "coverage/**",
    "*.min.js"
  ],
  "rules_files": [
    "AGENTS.md",
    ".github/epic-code-reviewer.md",
    ".github/copilot-instructions.md"
  ],
  "rules": "Report factual defects only. Do not comment on style unless a repo rule says so."
}
